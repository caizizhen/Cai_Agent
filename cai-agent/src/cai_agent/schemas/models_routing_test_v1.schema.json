{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cai-agent.local/schemas/models_routing_test_v1.schema.json",
  "title": "ModelsRoutingTestV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "role",
    "goal_preview",
    "model_routing_enabled",
    "rules_count",
    "cost_budget_max_tokens",
    "total_tokens_used",
    "base_profile_id",
    "effective_profile_id",
    "matched_rule"
  ],
  "properties": {
    "schema_version": { "const": "models_routing_test_v1" },
    "role": { "type": "string", "enum": ["active", "subagent", "planner"] },
    "goal_preview": { "type": "string" },
    "model_routing_enabled": { "type": "boolean" },
    "rules_count": { "type": "integer", "minimum": 0 },
    "cost_budget_max_tokens": { "type": "integer", "minimum": 0 },
    "total_tokens_used": { "type": "integer", "minimum": 0 },
    "cost_budget_remaining": {
      "type": ["integer", "null"]
    },
    "base_profile_id": { "type": "string" },
    "effective_profile_id": { "type": "string" },
    "matched_rule": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": true,
          "required": ["profile", "roles"],
          "properties": {
            "profile": { "type": "string" },
            "roles": {
              "type": "array",
              "items": { "type": "string" }
            },
            "goal_regex": { "type": ["string", "null"] },
            "goal_substring": { "type": ["string", "null"] },
            "cost_budget_remaining_tokens_below": { "type": ["integer", "null"] }
          }
        }
      ]
    },
    "explain": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "decision", "summary_zh", "summary_en"],
      "properties": {
        "schema_version": { "const": "routing_explain_v1" },
        "decision": {
          "type": "string",
          "enum": ["routing_disabled", "matched_rule", "fallback_active"]
        },
        "summary_zh": { "type": "string" },
        "summary_en": { "type": "string" }
      }
    },
    "fallback_candidates": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "mode", "auto_switch", "effective_profile_id", "count", "candidates"],
      "properties": {
        "schema_version": { "const": "model_fallback_candidates_v1" },
        "mode": { "const": "explain_only" },
        "auto_switch": { "const": false },
        "effective_profile_id": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["profile_id", "provider", "model", "score", "reasons", "capabilities"],
            "properties": {
              "profile_id": { "type": "string" },
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "score": { "type": "integer" },
              "reasons": {
                "type": "array",
                "items": { "type": "string" }
              },
              "capabilities": { "type": "object" }
            }
          }
        }
      }
    }
  }
}
